{
  "name": "codex-session-cli",
  "version": "1.1.1",
  "description": "一个跨平台的终端工具，用于查看OpenAI Codex CLI在当前目录下的历史session记录",
  "main": "dist/index.mjs",
  "bin": {
    "codex-sessions": "dist/index.mjs"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE",
    "CHANGELOG.md"
  ],
  "scripts": {
    "build": "tsup src/index.ts --format esm --no-dts",
    "build:watch": "tsup src/index.ts --format esm --no-dts --watch",
    "build:analyze": "tsup src/index.ts --format esm --no-dts --analyze",
    "clean": "rimraf dist",
    "prebuild": "npm run clean",
    "dev": "tsup src/index.ts --format esm --no-dts --watch",
    "test": "vitest --run",
    "test:watch": "vitest --watch",
    "test:coverage": "vitest --coverage",
    "lint": "eslint src --ext .ts,.tsx",
    "lint:fix": "eslint src --ext .ts,.tsx --fix",
    "format": "prettier --write src/**/*.{ts,tsx,json}",
    "typecheck": "tsc --noEmit",
    "check:all": "npm run typecheck && npm run lint && npm run test && npm run build",
    "prepublishOnly": "npm run check:all",
    "prepare": "husky install",
    "version": "npm run build && git add -A",
    "postversion": "git push && git push --tags",
    "publish:patch": "npm version patch && npm publish",
    "publish:minor": "npm version minor && npm publish",
    "publish:major": "npm version major && npm publish",
    "publish:next": "npm version prerelease && npm publish --tag next"
  },
  "keywords": [
    "codex",
    "cli",
    "session",
    "viewer",
    "terminal",
    "tui",
    "openai"
  ],
  "author": "Your Name",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/yourusername/codex-session-viewer.git"
  },
  "bugs": {
    "url": "https://github.com/yourusername/codex-session-viewer/issues"
  },
  "homepage": "https://github.com/yourusername/codex-session-viewer#readme",
  "engines": {
    "node": ">=18.0.0",
    "npm": ">=9.0.0"
  },
  "devDependencies": {
    "@types/fs-extra": "^11.0.4",
    "@types/node": "^20.0.0",
    "@types/react": "^18.0.0",
    "@typescript-eslint/eslint-plugin": "^6.0.0",
    "@typescript-eslint/parser": "^6.0.0",
    "eslint": "^8.0.0",
    "eslint-config-prettier": "^9.0.0",
    "eslint-plugin-react": "^7.0.0",
    "eslint-plugin-react-hooks": "^4.0.0",
    "husky": "^8.0.0",
    "lint-staged": "^15.0.0",
    "prettier": "^3.0.0",
    "rimraf": "^6.1.3",
    "tsup": "^8.0.0",
    "typescript": "^5.0.0",
    "vitest": "^1.0.0"
  },
  "dependencies": {
    "date-fns": "^3.0.0",
    "fs-extra": "^11.0.0",
    "ink": "^4.0.0",
    "ink-select-input": "^5.0.0",
    "ink-spinner": "^5.0.0",
    "ink-text-input": "^5.0.0",
    "react": "^18.0.0"
  },
  "lint-staged": {
    "*.{ts,tsx}": [
      "eslint --fix",
      "prettier --write"
    ],
    "*.json": [
      "prettier --write"
    ]
  }
}
