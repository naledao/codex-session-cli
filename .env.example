# Codex Session Viewer 环境变量配置

# 日志级别 (info, warn, error, debug)
LOG_LEVEL=info

# 默认会话路径 (默认: ~/.codex/sessions)
# SESSIONS_PATH=~/.codex/sessions

# 默认导出格式 (json, text, markdown, csv)
DEFAULT_EXPORT_FORMAT=json

# 最大搜索结果数
MAX_SEARCH_RESULTS=50

# 主题 (default, dark, light, colorful)
THEME=default

# 日期格式
DATE_FORMAT=yyyy-MM-dd HH:mm

# 是否显示时间戳
SHOW_TIMESTAMPS=true

# 是否高亮搜索匹配
HIGHLIGHT_MATCHES=true

# 语言 (zh, en)
LANGUAGE=zh

# 调试模式
DEBUG=false

# 配置文件路径
# CONFIG_PATH=~/.codex-session-viewer/config.json